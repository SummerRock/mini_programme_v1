[
  {
    "id": "quote_001",
    "text": "健康是最大的财富",
    "author": "维吉尔"
  },
  {
    "id": "quote_002",
    "text": "早睡早起，使人健康、富有、聪明",
    "author": "本杰明·富兰克林"
  },
  {
    "id": "quote_003",
    "text": "生命在于运动",
    "author": "伏尔泰"
  },
  {
    "id": "quote_004",
    "text": "千里之行，始于足下",
    "author": "老子"
  },
  {
    "id": "quote_005",
    "text": "身体是革命的本钱",
    "author": null
  },
  {
    "id": "quote_006",
    "text": "每一个不曾起舞的日子，都是对生命的辜负",
    "author": "尼采"
  },
  {
    "id": "quote_007",
    "text": "坚持就是胜利，每天进步一点点",
    "author": null
  },
  {
    "id": "quote_008",
    "text": "最好的医生是自己，最好的药物是时间，最好的运动是步行",
    "author": null
  },
  {
    "id": "quote_009",
    "text": "健康的身体是灵魂的客厅，病弱的身体是灵魂的监狱",
    "author": "培根"
  },
  {
    "id": "quote_010",
    "text": "你的身体是你唯一居住一辈子的地方，好好照顾它",
    "author": null
  }
]
