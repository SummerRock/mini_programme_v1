/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
} 
.common-page-container {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}
.common-text-size {
  font-size: 22rpx;
}
.common-text-color-normal {
  color: #1AAD19;
}
.common-darker-green {
  color: #2BA245;
}
.common-light-gray {
  color: #F1F1F1;
}
.common-normal-gray {
  color: #AAAAAA;
}
.common-deeper-gray {
  color: #888888;
}
.common-most-gray {
  color: #4D4D4D;
}