.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.date {
  font-size: 28rpx;
  color: #999;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.empty {
  text-align: center;
  color: #ccc;
  font-size: 26rpx;
  padding: 30rpx 0;
}

.record-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-name {
  font-size: 28rpx;
  color: #333;
}

.record-tag {
  font-size: 24rpx;
  color: #667eea;
  background: #f0f2ff;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.record-detail {
  margin-top: 8rpx;
  display: flex;
  gap: 20rpx;
}

.record-cal {
  font-size: 24rpx;
  color: #ff6b6b;
}

.record-note {
  font-size: 24rpx;
  color: #999;
}
