.page-container {
  padding: 24rpx;
  background: #F5F5F5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 日期选择器 */
.date-picker-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.date-picker-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-label {
  font-size: 28rpx;
  color: #999;
}

.date-value-wrap {
  display: flex;
  align-items: center;
}

.date-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 8rpx;
}

.date-arrow {
  font-size: 20rpx;
  color: #1AAD19;
}

/* 记录分区 */
.section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  font-size: 26rpx;
  color: #FFFFFF;
  background: #1AAD19;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}

/* 空数据占位 */
.empty-placeholder {
  text-align: center;
  color: #CCCCCC;
  font-size: 28rpx;
  padding: 40rpx 0;
}

/* 记录卡片 */
.record-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.record-card:last-child {
  border-bottom: none;
}

.record-card-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-card-name {
  font-size: 30rpx;
  color: #333;
}

.record-card-tag {
  font-size: 24rpx;
  color: #1AAD19;
  background: #E8F5E9;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.record-card-detail {
  margin-top: 8rpx;
}

.record-card-calories {
  font-size: 24rpx;
  color: #FF6B6B;
}
