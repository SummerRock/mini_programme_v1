<view class="mine-page">
  <!-- 用户信息区 -->
  <view class="profile-section" bindtap="onProfileTap">
    <image wx:if="{{avatarUrl}}" class="avatar" src="{{avatarUrl}}" />
    <view wx:else class="avatar default-avatar">
      <view class="default-avatar-icon"></view>
      <view class="default-avatar-body"></view>
    </view>
    <text class="nickname">{{nickname}}</text>
  </view>

  <!-- 饮食摘要区 -->
  <view class="diet-section">
    <text class="section-title">最近饮食</text>
    <!-- 未登录提示 -->
    <view wx:if="{{!isLoggedIn}}" class="diet-placeholder">请先登录查看饮食记录</view>
    <!-- 加载中 -->
    <view wx:elif="{{dietLoading}}" class="diet-placeholder">加载中...</view>
    <!-- 加载失败 -->
    <view wx:elif="{{dietError}}" class="diet-placeholder" bindtap="retryLoadDiet">加载失败，点击重试</view>
    <!-- 数据展示 -->
    <view wx:else>
      <view wx:for="{{dayGroups}}" wx:key="date" class="day-group">
        <text class="day-label">{{item.dateLabel}}</text>
        <view wx:if="{{item.records.length === 0}}" class="empty-tip">暂无记录</view>
        <view wx:for="{{item.records}}" wx:for-item="record" wx:key="_id" class="record-item">
          <text class="food-name">{{record.foodName}}</text>
          <text class="meal-type">{{record.mealTypeLabel}}</text>
          <text wx:if="{{record.calories > 0}}" class="calories">{{record.calories}} 千卡</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 健康管理入口 -->
  <view class="health-entry" bindtap="jumpToHealth">
    <image class="health-icon" src="../../images/ic_red_heart.png" />
    <view class="health-entry-text">
      <text class="health-title">健康管理</text>
      <text class="health-desc">管理饮食、运动和体重记录</text>
    </view>
    <text class="arrow">›</text>
  </view>

  <!-- 退出登录 -->
  <view wx:if="{{isLoggedIn}}" class="logout-btn" bindtap="loginout">退出登录</view>
</view>
