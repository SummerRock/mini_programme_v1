<wxs module="textUtils">
function truncate(content, maxLength) {
  if (!content) return ''
  if (content.length > maxLength) {
    return content.substring(0, maxLength) + '...'
  }
  return content
}
module.exports = { truncate: truncate }
</wxs>

<!-- Greeting_Banner -->
<view class="greeting-banner">
  <text class="greeting-text">{{greeting}}</text>
  <text class="greeting-date">{{displayDate}}</text>
</view>

<!-- Quotes_Section -->
<view class="section quotes-section">
  <text class="section-title">✨ 每日正能量</text>
  <view wx:if="{{loading}}" class="loading-placeholder">加载中...</view>
  <view wx:elif="{{quotesLoadError}}" class="error-text">内容加载失败</view>
  <view wx:else class="quote-card">
    <text class="quote-text">"{{currentQuote.text}}"</text>
    <text wx:if="{{currentQuote.author}}" class="quote-author">—— {{currentQuote.author}}</text>
  </view>
</view>

<!-- Tips_Section -->
<view class="section tips-section">
  <text class="section-title">💡 健康小贴士</text>
  <view wx:if="{{loading}}" class="loading-placeholder">加载中...</view>
  <view wx:elif="{{tipsLoadError}}" class="error-text">内容加载失败</view>
  <block wx:else>
    <view
      wx:for="{{tipsList}}"
      wx:key="id"
      class="tip-card {{expandedTipId === item.id ? 'tip-card-expanded' : ''}}"
      data-id="{{item.id}}"
      bindtap="onTipTap"
    >
      <text class="tip-title">{{item.title}}</text>
      <text class="tip-content" wx:if="{{expandedTipId === item.id}}">{{item.content}}</text>
      <text class="tip-content" wx:else>{{textUtils.truncate(item.content, 30)}}</text>
    </view>
  </block>
</view>
