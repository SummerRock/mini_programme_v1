/* 页面背景 */
page {
  background-color: #F5F5F5;
}

/* Greeting_Banner */
.greeting-banner {
  background: linear-gradient(135deg, #1AAD19, #12C343);
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.greeting-date {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* Section 通用 */
.section {
  padding: 30rpx 30rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

/* Quotes_Section */
.quote-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quote-text {
  font-size: 32rpx;
  color: #333333;
  line-height: 1.6;
  text-align: center;
}

.quote-author {
  font-size: 26rpx;
  color: #999999;
  margin-top: 20rpx;
  align-self: flex-end;
}

/* Tips_Section */
.tip-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  overflow: hidden;
}

.tip-card-expanded {
  box-shadow: 0 4rpx 16rpx rgba(26, 173, 25, 0.12);
}

.tip-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.tip-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  display: block;
}

/* 加载占位 */
.loading-placeholder {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  padding: 60rpx 0;
}

/* 错误状态 */
.error-text {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  padding: 60rpx 0;
}
