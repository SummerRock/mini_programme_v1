/* pages/food-wheel/index.wxss */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 转盘区域 */
.wheel-container {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
}

.wheel-wrapper {
  position: relative;
  width: 600rpx;
  height: 600rpx;
}

.wheel-canvas {
  width: 600rpx;
  height: 600rpx;
}

/* 指针 */
.pointer {
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-top: 40rpx solid #ff4757;
  z-index: 10;
}

/* 控制面板 */
.control-panel {
  display: flex;
  gap: 30rpx;
  margin-top: 60rpx;
}

.spin-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #ff4757;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.spin-btn[disabled] {
  background-color: #cccccc;
  color: #999999;
}

.edit-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #2ed573;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.edit-btn[disabled] {
  background-color: #cccccc;
  color: #999999;
}

/* 结果弹窗 */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.result-content {
  width: 500rpx;
  padding: 60rpx 40rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-title {
  font-size: 36rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.result-food {
  font-size: 56rpx;
  color: #ff4757;
  font-weight: bold;
  margin-bottom: 40rpx;
}

.retry-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #ff4757;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 32rpx;
}

/* 编辑模式弹窗 */
.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.edit-content {
  width: 600rpx;
  max-height: 80vh;
  padding: 40rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
}

.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.edit-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.edit-count {
  font-size: 28rpx;
  color: #999999;
}

/* 食物列表 */
.food-list {
  max-height: 400rpx;
  overflow-y: auto;
  margin-bottom: 30rpx;
}

.food-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.food-input {
  flex: 1;
  height: 60rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dddddd;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.delete-btn {
  margin-left: 20rpx;
  padding: 10rpx 20rpx;
  background-color: #ff4757;
  color: #ffffff;
  border-radius: 10rpx;
  font-size: 24rpx;
}

/* 添加区域 */
.add-section {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.add-input {
  flex: 1;
  height: 60rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dddddd;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.add-btn {
  margin-left: 20rpx;
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #2ed573;
  color: #ffffff;
  border-radius: 10rpx;
  font-size: 28rpx;
  padding: 0;
}

/* 操作按钮 */
.edit-actions {
  display: flex;
  justify-content: space-between;
  gap: 30rpx;
}

.cancel-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #cccccc;
  color: #666666;
  border-radius: 10rpx;
  font-size: 32rpx;
}

.save-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #2ed573;
  color: #ffffff;
  border-radius: 10rpx;
  font-size: 32rpx;
}
