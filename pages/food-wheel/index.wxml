<view style="padding:40rpx;background:#f0f0f0;min-height:100vh;">
  <view style="text-align:center;font-size:36rpx;font-weight:bold;color:#333;margin-bottom:40rpx;">今天吃什么</view>
  
  <view style="width:500rpx;height:500rpx;margin:0 auto;border-radius:50%;background:#FFE66D;display:flex;align-items:center;justify-content:center;transform:rotate({{angle}}deg);box-shadow:0 4rpx 20rpx rgba(0,0,0,0.2);">
    <view style="text-align:center;">
      <view wx:for="{{foods}}" wx:key="index" style="font-size:28rpx;color:#333;padding:10rpx 0;">{{item}}</view>
    </view>
  </view>
  
  <view style="text-align:center;margin-top:40rpx;">
    <button style="display:inline-block;margin:10rpx;padding:20rpx 60rpx;background:#ff4757;color:#fff;border-radius:40rpx;" bindtap="spin" disabled="{{running}}">
      {{running ? '转动中...' : '开始'}}
    </button>
    <button style="display:inline-block;margin:10rpx;padding:20rpx 60rpx;background:#667eea;color:#fff;border-radius:40rpx;" bindtap="edit">
      编辑
    </button>
  </view>
  
  <view wx:if="{{showRes}}" style="position:fixed;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;">
    <view style="background:#fff;padding:60rpx;border-radius:20rpx;text-align:center;">
      <view style="font-size:32rpx;color:#666;">今天吃</view>
      <view style="font-size:56rpx;color:#ff4757;font-weight:bold;margin:20rpx 0;">{{res}}</view>
      <button style="background:#667eea;color:#fff;padding:20rpx 60rpx;border-radius:40rpx;" bindtap="hideRes">再来</button>
    </view>
  </view>
  
  <view wx:if="{{showEdit}}" style="position:fixed;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;">
    <view style="background:#fff;padding:40rpx;border-radius:20rpx;width:560rpx;">
      <view style="font-size:32rpx;font-weight:bold;margin-bottom:20rpx;">编辑食物 ({{foods.length}}/8)</view>
      <view wx:for="{{foods}}" wx:key="index" style="display:flex;align-items:center;margin-bottom:16rpx;">
        <input style="flex:1;height:60rpx;background:#f5f5f5;padding:0 16rpx;border-radius:8rpx;" value="{{item}}" data-i="{{index}}" bindinput="chg" maxlength="4"/>
        <view style="margin-left:16rpx;padding:10rpx 20rpx;background:#ff4757;color:#fff;border-radius:8rpx;" data-i="{{index}}" bindtap="del">删除</view>
      </view>
      <view style="display:flex;align-items:center;margin:20rpx 0;">
        <input style="flex:1;height:60rpx;background:#f5f5f5;padding:0 16rpx;border-radius:8rpx;" placeholder="新增食物" value="{{newF}}" bindinput="newInput" maxlength="4"/>
        <view style="margin-left:16rpx;padding:10rpx 20rpx;background:#667eea;color:#fff;border-radius:8rpx;" bindtap="addF">添加</view>
      </view>
      <view style="display:flex;gap:20rpx;margin-top:30rpx;">
        <button style="flex:1;background:#eee;color:#666;padding:20rpx 0;border-radius:8rpx;" bindtap="cancelE">取消</button>
        <button style="flex:1;background:#667eea;color:#fff;padding:20rpx 0;border-radius:8rpx;" bindtap="saveE">保存</button>
      </view>
    </view>
  </view>
</view>
