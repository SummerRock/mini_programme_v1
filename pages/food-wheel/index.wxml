<!--pages/food-wheel/index.wxml-->
<view class="container">
  <!-- 转盘区域 -->
  <view class="wheel-container">
    <view class="wheel-wrapper">
      <canvas type="2d" id="wheelCanvas" class="wheel-canvas"></canvas>
      <!-- 指针 -->
      <view class="pointer"></view>
    </view>
  </view>

  <!-- 控制按钮 -->
  <view class="control-panel">
    <button class="spin-btn" bindtap="startSpin" disabled="{{isSpinning}}">
      {{isSpinning ? '旋转中...' : '开始'}}
    </button>
    <button class="edit-btn" bindtap="enterEditMode" disabled="{{isSpinning}}">编辑</button>
  </view>

  <!-- 结果展示弹窗 -->
  <view class="result-modal" wx:if="{{showResult}}">
    <view class="result-content">
      <text class="result-title">今天吃</text>
      <text class="result-food">{{selectedFood}}</text>
      <button class="retry-btn" bindtap="resetSpin">再转一次</button>
    </view>
  </view>

  <!-- 编辑模式 -->
  <view class="edit-modal" wx:if="{{isEditMode}}">
    <view class="edit-content">
      <view class="edit-header">
        <text class="edit-title">编辑食物列表</text>
        <text class="edit-count">{{foodItems.length}}/{{MAX_FOOD_COUNT}}</text>
      </view>
      
      <!-- 食物列表 -->
      <view class="food-list">
        <view class="food-item" wx:for="{{foodItems}}" wx:key="index">
          <input 
            class="food-input" 
            value="{{item}}" 
            data-index="{{index}}"
            bindinput="onFoodInputChange"
            bindblur="onFoodInputBlur"
            maxlength="10"
          />
          <view class="delete-btn" bindtap="deleteFoodItem" data-index="{{index}}">删除</view>
        </view>
      </view>

      <!-- 添加新食物 -->
      <view class="add-section">
        <input 
          class="add-input" 
          placeholder="输入新食物名称" 
          value="{{newFoodName}}"
          bindinput="onNewFoodInput"
          maxlength="10"
        />
        <button class="add-btn" bindtap="addFoodItem">添加</button>
      </view>

      <!-- 操作按钮 -->
      <view class="edit-actions">
        <button class="cancel-btn" bindtap="exitEditMode">取消</button>
        <button class="save-btn" bindtap="saveFoodItems">保存</button>
      </view>
    </view>
  </view>
</view>
